# ── PostgreSQL (used by docker-compose to create the database container) ───────
# These three variables are read by docker-compose.yml to configure the
# postgres service AND to build the DATABASE_URL for the API container.
# If you change them here, the API will connect correctly automatically.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=invoice_sync

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Ecommerce Invoice Sync API"
APP_VERSION="1.0.0"
DEBUG=false

ALLOWED_HOSTS=["*"]

# ── Database ───────────────────────────────────────────────────────────────────
# In Docker, DATABASE_URL is overridden automatically by docker-compose.yml
# using the POSTGRES_* variables above. For local development (without Docker)
# update the credentials below to match your local PostgreSQL instance.
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-db-password@localhost:5432/invoice_sync
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Static API key for B2B machine-to-machine integrations
# Generate with: openssl rand -hex 24
API_KEY_NAME=X-API-Key
API_KEY=change-me-strong-api-key

# ── External Billing System ────────────────────────────────────────────────────
BILLING_SYSTEM_URL=https://billing.example.com/api/v1
BILLING_SYSTEM_API_KEY=your-external-billing-api-key
BILLING_SYSTEM_TIMEOUT=10
# Set to true in development/test to skip real billing calls (returns simulated ID)
BILLING_SYSTEM_MOCK=true

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=facturas@tudominio.com
# Set to false in production to enable real email delivery
EMAIL_MOCK=true

# ── Webhooks ───────────────────────────────────────────────────────────────────
# Leave WEBHOOK_URL empty to disable webhook dispatch entirely
WEBHOOK_URL=
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-webhook-secret-at-least-32-chars
# Set to false in production to enable real webhook dispatch
WEBHOOK_MOCK=true

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to true in production for structured JSON logs (Datadog, Loki, CloudWatch)
LOG_JSON=false
